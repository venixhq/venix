# Database
DATABASE_URL=postgresql://user:password@localhost/dbname
TEST_DATABASE_URL=postgresql://user:password@localhost/dbname_test

# Auth / Security
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email
RESEND_API_KEY=resend_api_key
MAIL_FROM=your_domain@email.com

# Application
ENV=development
BASE_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000"]

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Redis 
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=False

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
FRONTEND_SUCCESS_URL=http://localhost:3000/checkout/success
FRONTEND_CANCEL_URL=http://localhost:3000/checkout/cancel

# Bootstrap Admin Seeding (run once at deploy, then remove)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_FIRST_NAME=
# SEED_ADMIN_LAST_NAME=